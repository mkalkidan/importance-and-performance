    "# importing packages\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.model_selection import cross_val_score\n",
    "from sklearn.model_selection import train_test_split\n",
    "import numpy as np\n",
    "import scipy.io\n",
    "import os\n",
    "import numpy as np\n",
    "from scipy.stats import pearsonr\n",
    "import lime \n",
    "import lime.lime_tabular\n",
    "import numpy as np \n",
    "from sklearn.metrics import roc_auc_score"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "efc220c6-2ea5-47ef-9bde-43b2d598495a",
   "metadata": {},
   "source": [
    "### Load the dataset\n",
    "we use expanduser to help the notebook start form the parent folder and not from current directory, \n",
    "we have Loaded the dataset only the dataset 1.\n",
    "Improvement = map the dataset to the name \n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "6a70ea1b-8b6f-484b-a897-fe233d30455e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Loaded successfully. Features shape: (198, 33), Labels shape: (198, 1)\n"
     ]
    }
   ],
   "source": [
    "\n",
    "# Define the base path (adjust path if needed)\n",
    "base_dir = os.path.join(os.path.expanduser(\"~\"), \"Desktop\", \"TEAM - Dataset\", \"data\")\n",
    "\n",
    "# Load only the first dataset\n",
    "data = scipy.io.loadmat(os.path.join(base_dir, \"1\", \"data.mat\"))\n",
    "\n",
    "# Extract variabl\n",
    "X, y = data['X'], data['y']\n",
    "\n",
    "print(f\"Loaded successfully. Features shape: {X.shape}, Labels shape: {y.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "793d9792-e82e-4897-bed3-872946e8789e",
   "metadata": {},
   "source": [
    "### We split then initialise the model then we train the model then we evaluate it using cross val on the training set\n",
    "\n",
    "variables created here are X_train, X_test, y_train, y_test \n",
    "LR_model\n",
    "LR_crossval_score"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 43,
   "id": "df0802a7-d24d-42f6-b3a3-8062fd6a02b5",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "# Create the training and testing sets explicitly \n",
    "X_train, X_test, y_train, y_test = train_test_split(X, y.ravel(), test_size = 0.2, random_state = 42)\n",
    "# initialise the model \n",
    "LR_model = LogisticRegression(max_iter = 1000)\n",
    "# fit the model \n",
    "LR_model.fit(X_train, y_train)\n",
    "# corss validate on the 80% training data\n",
    "LR_crossval_score = cross_val_score(LR_model, X_train, y_train.ravel(), cv = 5)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ebc57a25-24f8-47b6-91e7-812df77a6648",
   "metadata": {},
   "source": [
    "### Questions \n",
    "If crossval is just evaluation is it not better to use the entire dataset \n",
    "\n",
    "using the cross val on the 80 percent of the training set so it won't be data lekage.\n",
    "So it depends on how we use the result of the cv score if we use the tune it then it is data leakage but if just use it to have an honest review of our score then that is fine evaluation. \n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 46,
   "id": "edcbc5fe-e4b0-436a-a0e5-bb215b9fada5",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[0.78125    0.875      0.75       0.70967742 0.77419355]\n"
     ]
    }
   ],
   "source": [
    "print(LR_crossval_score)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ef0b40c8-58ae-40b1-94f0-13f84ae10fbf",
   "metadata": {},
   "source": [
    "### Calculating the AUC of the orginal data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 105,
   "id": "7aec1a0f-9e35-47e0-9070-6931111790ee",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "AUC score on orginal instances:  0.8828\n"
     ]
    }
   ],
   "source": [
    "y_pred_proba_orginal = LR_model.predict_proba(X)[:,1]\n",
    "auc_score = roc_auc_score(y,y_pred_proba_orginal)\n",
    "print(f\"AUC score on orginal instances: {auc_score: .4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "5c7f6b5d-0204-4b14-9878-5374d70d5404",
   "metadata": {},
   "source": [
    "### Creating a matrix of feature importance for each sample using shap \n",
    "initialise the explainer \n",
    "calculate the shap value to the entire dataset\n",
    "\n",
    "why we use masker?\n",
    "Linear Explainer defaults to a masker object that sometimes imposes its own internal limits setting the max_sample to 100 but we have 158 samples so we need to force it "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 39,
   "id": "56a89b61-2ca7-4b38-b23e-cedb372001c9",
   "metadata": {},
   "outputs": [],
   "source": [
    "import shap\n",
    "masker = shap.maskers.Independent(data = X_train , max_samples = 158)\n",
    "\n",
    "# Initialize the shap explainer \n",
    "explainer = shap.LinearExplainer(LR_model,masker = masker)\n",
    "\n",
    "# shap values for the entire dataset \n",
    "LR_shap = explainer.shap_values(X)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 41,
   "id": "2b22b543-ee26-4816-beb9-72076027ce30",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Shap values shape: (198, 33)\n"
     ]
    }
   ],
   "source": [
    "print (\"Shap values shape:\", LR_shap.shape)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "0bef2ff8-f2ca-4a20-9e20-5c156c3c8ac4",
   "metadata": {},
   "source": [
    "### Creating a matrix of feature importance for each sample using LIME\n",
    "(Local Interpretable Model- agnostic Explanations) itakes specific data instance slightly change the features of that instance to create a new dataawr os fake weightin g thiese examples based on how close they are to the original instance Training a simple interpretable \n",
    "\n",
    "explainer_lime.explain_instance requires an input of one single row (or instance) of data.\n",
    "explain_instance returns an object (exp) that contains the feature contributions for that specific input.\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "the first loop feeds the explainer each samples , the second and third collect the result and put it in matrix \n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 58,
   "id": "31f1485a-6ecf-4db0-9b56-490eedfb8f97",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Generating LIME values...\n",
      "LIME matrix shape: (198, 33)\n"
     ]
    }
   ],
   "source": [
    "# Create a mapping of feature names (e.g., 'f0') to indices (e.g., 0)\n",
    "feature_to_idx = {f\"f{i}\": i for i in range(X.shape[1])}\n",
    "\n",
    "# Loop through all 198 instances\n",
    "print(\"Generating LIME values...\")\n",
    "for i in range(len(X)):\n",
    "    exp = explainer_lime.explain_instance(X[i], LR_model.predict_proba)\n",
    "    \n",
    "    # exp.as_list() returns tuples like ('f0 > 0.50', 0.12)\n",
    "    for description, importance in exp.as_list(label=1):\n",
    "        # Find which feature name exists in the description\n",
    "        for feat_name, idx in feature_to_idx.items():\n",
    "            if feat_name in description:\n",
    "                LR_LIME[i, idx] = importance\n",
    "                break \n",
    "\n",
    "print(\"LIME matrix shape:\", LR_LIME.shape)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4363ebd6-fd87-410b-84f3-5ae3143d91a5",
   "metadata": {},
   "source": [
    "### The Importance consistency be\n",
    "first initialise an array to hod the IC scores for each instances \n",
    "calculate pearson correlation between each vectors \n",
    "now i c is 1D array of 198 values representing the agreement\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 83,
   "id": "d4870160-371b-4311-9bdc-fbcde94b652d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# array\n",
    "LR_IC_scores = np.zeros(len(X))\n",
    "for i in range( len(X)):\n",
    "    correlation, _ = pearsonr(LR_shap[i], LR_LIME[i])\n",
    "    LR_IC_scores[i] = correlation"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4628ff8d-5315-49e8-a302-c3e71188cc84",
   "metadata": {},
   "source": []
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e9d6a351-3bd2-4c61-86c2-50988b37d17d",
   "metadata": {},
   "outputs": [],
   "source": []
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "dd5a2dcd-86bb-4285-b21b-727798b41aab",
   "metadata": {},
   "outputs": [],
   "source": []
  },
  {
   "cell_type": "code",
   "execution_count": 84,
   "id": "cd6de2dd-adfd-42e5-b32a-fc6eeeb92777",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "# Calculate the 25th and 75th percentiles\n",
    "bottom_25 = np.percentile(LR_IC_scores, 25)\n",
    "top_25 = np.percentile(LR_IC_scores, 75)\n",
    "\n",
    "# Plotting the histogram\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.hist(LR_IC_scores, bins=30, color='skyblue', edgecolor='black', alpha=0.7)\n",
    "\n",
    "# Adding the threshold lines\n",
    "plt.axvline(bottom_25, color='red', linestyle='dashed', linewidth=2, label=f'Bottom 25% (Threshold: {bottom_25:.2f})')\n",
    "plt.axvline(top_25, color='green', linestyle='dashed', linewidth=2, label=f'Top 25% (Threshold: {top_25:.2f})')\n",
    "\n",
    "# Adding labels and title\n",
    "plt.title('Distribution of Interpretation Consistency (SHAP vs LIME)', fontsize=14)\n",
    "plt.xlabel('Pearson Correlation (IC Score)', fontsize=12)\n",
    "plt.ylabel('Frequency', fontsize=12)\n",
    "plt.legend()\n",
    "plt.grid(axis='y', alpha=0.3)\n",
    "\n",
    "plt.show()"
   ]
  },
  {
